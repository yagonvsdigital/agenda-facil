{
  "expo": {
    "name": "Secretaria Digital",
    "slug": "secretaria-digital",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "secretariadigital",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d9488"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.secretariadigital.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Usar câmera para escanear QR Code do profissional",
        "NSMicrophoneUsageDescription": "Necessário para câmera"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#38B2E8"
      },
      "package": "com.secretariadigital.app",
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Precisamos da câmera para escanear o QR Code do seu profissional."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0d9488"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "4f4289d7-c20b-4efd-99cf-e5b11f846318"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "yagonvsdigital"
  }
}

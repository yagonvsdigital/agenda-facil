# App
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=corteja
DB_PASS=corteja_pass
DB_NAME=corteja_db

# JWT
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=7d

# OTP via SMS (Twilio — preencha para SMS real, deixe vazio para modo dev com código fixo)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase Cloud Messaging (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# CORS
FRONTEND_URL=http://localhost:5173
